{
	"info": {
		"name": "Family Expense Tracker - Category Module",
		"description": "Complete API collection for the Category module of the Family Expense Tracker application.\n\n## Setup Instructions\n1. First, call the Login/Signup endpoint from your Auth collection\n2. Copy the JWT token from the response\n3. Set the `token` variable in this collection to the JWT value\n\nAll category endpoints require JWT authentication.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "YOUR_JWT_TOKEN_HERE",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoints to obtain JWT token",
			"item": [
				{
					"name": "Signup",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Family Admin\",\n    \"email\": \"family@example.com\",\n    \"password\": \"Password@123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/signup",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "signup"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token saved automatically!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"family@example.com\",\n    \"password\": \"Password@123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token saved automatically!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "Categories",
			"description": "Category CRUD operations - All endpoints require JWT Bearer token",
			"item": [
				{
					"name": "1. Get All Categories",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/categories",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories"]
						}
					}
				},
				{
					"name": "2. Get Category by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/categories/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories", "1"]
						}
					}
				},
				{
					"name": "3. Create Category",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Travel\",\n    \"icon\": \"✈️\",\n    \"colorHex\": \"#3498DB\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/categories",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories"]
						}
					}
				},
				{
					"name": "4. Update Category",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Travel & Vacation\",\n    \"icon\": \"🌍\",\n    \"colorHex\": \"#2980B9\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/categories/11",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories", "11"]
						}
					}
				},
				{
					"name": "5. Delete Category",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/categories/11",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories", "11"]
						}
					}
				},
				{
					"name": "6. Create Duplicate Category (Error Test)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Food & Dining\",\n    \"icon\": \"🍕\",\n    \"colorHex\": \"#E74C3C\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/categories",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories"]
						}
					}
				},
				{
					"name": "7. Update Default Category (Error Test)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"My Food\",\n    \"icon\": \"🍕\",\n    \"colorHex\": \"#E74C3C\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/categories/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories", "1"]
						}
					}
				},
				{
					"name": "8. Delete Default Category (Error Test)",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/categories/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories", "1"]
						}
					}
				},
				{
					"name": "9. Get Non-Existent Category (Error Test)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/categories/999",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories", "999"]
						}
					}
				},
				{
					"name": "10. Create Category - Validation Error (Error Test)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"\",\n    \"icon\": \"\",\n    \"colorHex\": \"invalid\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/categories",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories"]
						}
					}
				}
			]
		}
	]
}
